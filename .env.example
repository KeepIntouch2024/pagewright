# Copy to .env (auto-loaded). Only the key for your chosen backend is required.

# --- LLM backend (pick ONE; nothing here is hard-wired to Claude) ---
PAGEWRIGHT_LLM=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI or ANY OpenAI-compatible endpoint (DeepSeek, Qwen, Moonshot, Together, ...):
# PAGEWRIGHT_LLM=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com
# PAGEWRIGHT_MODEL=deepseek-chat

# Fully LOCAL via Ollama (no cloud, no key — needs a vision model for the extract step):
# PAGEWRIGHT_LLM=openai
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# PAGEWRIGHT_MODEL=qwen2.5vl          # or llama3.2-vision, minicpm-v, etc.

# Local via vLLM / LM Studio / llama.cpp server: same pattern, point OPENAI_BASE_URL at it.
# PAGEWRIGHT_MODEL=                  # override default model id for any backend

# --- rendering ---
# PAGEWRIGHT_WIDTH=750              # detail-page width (px)
# PAGEWRIGHT_SCALE=2               # device scale factor (1.8 keeps tall pages under Chrome's cap)

# --- acquisition ---
# PAGEWRIGHT_CDP_URL=http://localhost:9222   # tier-3: your real Chrome's debug endpoint
# PAGEWRIGHT_RESPECT_ROBOTS=1                # set 0 only for pages you're authorized to access
# PAGEWRIGHT_RATE_LIMIT=1.0                  # seconds between requests
# PAGEWRIGHT_UA=                             # custom User-Agent
